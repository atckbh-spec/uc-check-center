{
  "name": "uc-check",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "qa:build-output": "node scripts/verify-build-output.mjs",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "deploy:preflight": "node scripts/deploy-preflight.mjs",
    "deploy:smoke": "node scripts/deploy-smoke.mjs",
    "deploy:check": "npm run typecheck && npm run lint && npm run build && npm run qa:build-output && npm run deploy:preflight",
    "center:preflight": "node scripts/center-preflight.mjs",
    "center:check": "npm run typecheck && npm run lint && npm run build && npm run qa:build-output && npm run security:static && npm run center:preflight",
    "security:static": "node scripts/security-static-audit.mjs",
    "security:routes": "node scripts/security-route-smoke.mjs",
    "security:db": "node scripts/security-db-audit.mjs",
    "security:check": "npm run security:static && npm run qa:build-output",
    "security:full": "npm run security:check && npm run security:db && npm run security:routes",
    "security:roles": "node scripts/security-role-matrix.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^14.2.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
