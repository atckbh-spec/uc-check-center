# UC Check production environment example
# Do not commit real .env.production.local values.

NEXT_PUBLIC_SUPABASE_URL=https://your-production-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-production-service-role-key
NEXT_PUBLIC_APP_URL=https://check.urban-conditioning.example
NEXT_PUBLIC_DEMO_MODE=false

# Staff-only kiosk unlock PIN. Use at least 6 digits in production.
KIOSK_UNLOCK_PIN=replace-with-6-plus-digit-pin

# Generate with: openssl rand -base64 48
KIOSK_COOKIE_SECRET=replace-with-long-random-string

# Generate with: openssl rand -base64 48
MEMBER_PIN_PEPPER=replace-with-another-long-random-string
