NEXT_PUBLIC_SUPABASE_URL=https://<your-center-supabase-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>
NEXT_PUBLIC_APP_URL=https://<center-operations-domain>
NEXT_PUBLIC_DEMO_MODE=false
KIOSK_UNLOCK_PIN=<6-plus-digit-staff-kiosk-pin>
KIOSK_COOKIE_SECRET=<long-random-cookie-secret>

# Long random secret used as a pepper when hashing member kiosk PINs.
# Existing legacy hashes are still accepted, but new hashes use this value.
MEMBER_PIN_PEPPER=<long-random-member-pin-pepper>

# Do not put real center secrets in source code or ZIP packages.
# Store real values only in Vercel/Supabase environment variable settings.
