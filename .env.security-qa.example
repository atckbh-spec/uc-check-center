# UC Check Security QA environment example
# Copy to .env.local or export values in your shell before running security QA scripts.

NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-server-only

# Used by live app smoke tests.
UC_CHECK_PRODUCTION_URL=https://replace-with-production-domain.vercel.app

# Optional authenticated role matrix tests.
# Create these users only in QA/staging first. Production role tests should use dedicated temporary accounts.
SECURITY_QA_OWNER_EMAIL=owner@urban-conditioning.test
SECURITY_QA_OWNER_PASSWORD=replace-with-password
SECURITY_QA_ADMIN_EMAIL=admin@urban-conditioning.test
SECURITY_QA_ADMIN_PASSWORD=replace-with-password
SECURITY_QA_COACH_EMAIL=coach@urban-conditioning.test
SECURITY_QA_COACH_PASSWORD=replace-with-password
SECURITY_QA_FRONT_DESK_EMAIL=front@urban-conditioning.test
SECURITY_QA_FRONT_DESK_PASSWORD=replace-with-password

# Keep mutation tests disabled unless you are using a disposable QA DB.
SECURITY_QA_ENABLE_MUTATION_TESTS=false
